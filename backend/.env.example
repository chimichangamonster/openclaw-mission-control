# Mission Control Backend — Environment Variables
# Copy to .env and fill in values. Lines with values are defaults; blank = required.

# ─── Core ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/mission_control
# REQUIRED for gateway provisioning/agent heartbeats. Must be reachable by gateway.
BASE_URL=http://localhost:8000
# Comma-separated allowed origins (frontend URL)
CORS_ORIGINS=http://localhost:3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Auth mode: local (shared token), clerk (Clerk JWT), or wechat (WeChat OAuth)
AUTH_MODE=local
# REQUIRED when AUTH_MODE=local (minimum 50 chars, non-placeholder)
# Generate: openssl rand -hex 32
LOCAL_AUTH_TOKEN=
# Clerk (required when AUTH_MODE=clerk)
CLERK_SECRET_KEY=
CLERK_API_URL=https://api.clerk.com
CLERK_VERIFY_IAT=true
CLERK_LEEWAY=10.0
# WeChat (required when AUTH_MODE=wechat)
# WECHAT_CORP_ID=
# WECHAT_APP_SECRET=
# WECHAT_AGENT_ID=

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256-GCM encryption key for secrets at rest (API keys, OAuth tokens, etc.)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_USE_UTC=false
REQUEST_LOG_SLOW_MS=1000
REQUEST_LOG_INCLUDE_HEALTH=false

# ─── Database ─────────────────────────────────────────────────────────────────
DB_AUTO_MIGRATE=false

# ─── Redis / Job Queue ────────────────────────────────────────────────────────
RQ_REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=default
RQ_DISPATCH_THROTTLE_SECONDS=15.0
RQ_DISPATCH_MAX_RETRIES=3

# ─── LLM ──────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your-key-here

# ─── Gateway Workspaces ───────────────────────────────────────────────────────
# Per-org gateway workspaces root (preferred — each org gets a subdirectory)
GATEWAY_WORKSPACES_ROOT=
# Legacy single-workspace fallback (used when GATEWAY_WORKSPACES_ROOT is not set)
# GATEWAY_WORKSPACE_PATH=
GATEWAY_MIN_VERSION=2026.02.9

# ─── Email OAuth — Zoho (Canadian datacenter: zohocloud.ca) ───────────────────
ZOHO_OAUTH_CLIENT_ID=
ZOHO_OAUTH_CLIENT_SECRET=
ZOHO_OAUTH_REDIRECT_URI=

# ─── Email OAuth — Microsoft (Outlook + OneDrive + Calendar) ──────────────────
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=
MICROSOFT_OAUTH_TENANT_ID=common
# Separate redirect for OneDrive/Calendar (if different from email)
# MICROSOFT_GRAPH_REDIRECT_URI=

# ─── Calendar OAuth — Google ──────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# ─── Email Sync ───────────────────────────────────────────────────────────────
EMAIL_SYNC_INTERVAL_SECONDS=300
EMAIL_SYNC_QUEUE_NAME=email_sync

# ─── Discord ──────────────────────────────────────────────────────────────────
# Bot token for #notifications channel posts
# DISCORD_BOT_TOKEN=

# ─── PDF Services (optional — fallback to reportlab if not set) ───────────────
# ADOBE_PDF_CLIENT_ID=
# ADOBE_PDF_CLIENT_SECRET=

# ─── Security Headers (blank disables) ────────────────────────────────────────
SECURITY_HEADER_X_CONTENT_TYPE_OPTIONS=
SECURITY_HEADER_X_FRAME_OPTIONS=
SECURITY_HEADER_REFERRER_POLICY=
SECURITY_HEADER_PERMISSIONS_POLICY=
